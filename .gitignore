# -----------------------------------------------------------------------------
# Python runtime and virtual environments
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.env

# -----------------------------------------------------------------------------
# Local databases and generated scientific outputs
# Keep source data and code in git; ignore generated run artifacts.
# -----------------------------------------------------------------------------
data/*.db
data/plots/
data/qspr_results/
data/dumps/
data/logs/

# -----------------------------------------------------------------------------
# Legacy research artifacts and historical scratch work
# These are not required for platform runtime or deployment.
# -----------------------------------------------------------------------------
legacy/
scratch/

# -----------------------------------------------------------------------------
# Temporary tests / ad hoc local experiments
# -----------------------------------------------------------------------------
tests/test_*.py

# -----------------------------------------------------------------------------
# IDE and OS metadata
# -----------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
